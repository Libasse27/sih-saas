# Consommé par le conteneur `api` via env_file (docker-compose.prod.yml). À copier en
# apps/api/.env.production, jamais commité. Hôtes = noms des services docker-compose (réseau
# interne `sih_saas_net`), jamais `localhost` (qui désignerait le conteneur api lui-même).
NODE_ENV=production
PORT=3000
API_PREFIX=api
# Domaine(s) réels des consoles desktop/établissement en production, séparés par des virgules.
CORS_ORIGINS=https://app.votre-domaine.sn

# PostgreSQL — port interne standard (5432), jamais exposé sur l'hôte (voir docker-compose.prod.yml).
# POSTGRES_PASSWORD doit être IDENTIQUE à SIH_SAAS_APP_PASSWORD (.env.production racine) : c'est le
# même rôle applicatif sih_saas_app créé par postgres-init-prod/01-create-app-role.sh.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sih_saas_app
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=sih_saas

# MongoDB — MONGO_ROOT_USER/PASSWORD doivent correspondre à .env.production (racine).
MONGODB_URI=mongodb://sih_saas:change-me-strong-password@mongodb:27017/sih_saas?authSource=admin

# Redis — REDIS_PASSWORD doit correspondre à .env.production (racine).
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-strong-password

# JWT — secrets longs et aléatoires, jamais réutilisés du fichier .env de développement.
JWT_ACCESS_SECRET=change-me-strong-random-secret
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-strong-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Sécurité
BCRYPT_ROUNDS=12
LOGIN_MAX_TENTATIVES=5
LOGIN_VERROUILLAGE_MINUTES=15

# Bootstrap (premier super-admin de la plateforme — à ne lancer qu'une fois, voir
# apps/api/src/database/seeds/super-admin.seed.ts, puis changer immédiatement le mot de passe).
SUPER_ADMIN_EMAIL=superadmin@votre-domaine.sn
SUPER_ADMIN_PASSWORD=change-me-immediately-after-first-login

# Email — passerelle SMTP réelle en production (jamais MAIL_TRANSPORT=dev).
MAIL_TRANSPORT=smtp
MAIL_FROM=no-reply@votre-domaine.sn
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# Paiement — seule la passerelle SANDBOX est implémentée à ce jour (voir docs/phase-0/plan-de-phases.md).
PAYMENT_SANDBOX_WEBHOOK_SECRET=change-me-strong-random-secret
