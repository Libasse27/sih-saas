# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# PostgreSQL
# Port hôte 5433 (et non 5432) pour éviter un conflit avec un autre projet local utilisant déjà 5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=sih_saas
POSTGRES_PASSWORD=sih_saas_dev_password
POSTGRES_DB=sih_saas

# MongoDB — port hôte 27018 (et non 27017) pour la même raison.
MONGODB_URI=mongodb://sih_saas:sih_saas_dev_password@localhost:27018/sih_saas?authSource=admin

# Redis (cache/jobs — câblé à partir de la Phase 3) — port hôte 6380 (et non 6379) pour la même raison.
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-dev-only
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret-dev-only
JWT_REFRESH_EXPIRES_IN=30d

# Sécurité
BCRYPT_ROUNDS=12
LOGIN_MAX_TENTATIVES=5
LOGIN_VERROUILLAGE_MINUTES=15

# Bootstrap (seed initial, dev uniquement)
SUPER_ADMIN_EMAIL=superadmin@sih-saas.local
SUPER_ADMIN_PASSWORD=ChangeMe123!
