# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
# Liste séparée par virgules — origines autorisées en CORS (la console desktop Vite en dev).
CORS_ORIGINS=http://localhost:5173

# PostgreSQL
# Port hôte 5433 (et non 5432) pour éviter un conflit avec un autre projet local utilisant déjà 5432.
# IMPORTANT : sih_saas_app (et non sih_saas) — sih_saas est le rôle bootstrap superuser de l'image
# Docker Postgres, et Postgres ignore TOUJOURS les policies RLS pour un superuser. L'app doit se
# connecter avec le rôle non-superuser créé par infrastructure/docker/postgres-init/01-create-app-role.sql.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=sih_saas_app
POSTGRES_PASSWORD=sih_saas_app_dev_password
POSTGRES_DB=sih_saas

# MongoDB — port hôte 27018 (et non 27017) pour la même raison.
MONGODB_URI=mongodb://sih_saas:sih_saas_dev_password@localhost:27018/sih_saas?authSource=admin

# Redis (cache/jobs — câblé à partir de la Phase 3) — port hôte 6380 (et non 6379) pour la même raison.
REDIS_HOST=localhost
REDIS_PORT=6380

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-dev-only
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh-secret-dev-only
JWT_REFRESH_EXPIRES_IN=30d

# Sécurité
BCRYPT_ROUNDS=12
LOGIN_MAX_TENTATIVES=5
LOGIN_VERROUILLAGE_MINUTES=15

# Optionnel — n'assouplir QUE dans un environnement CI/e2e éphémère (jamais en dev/prod) : la
# suite Cypress (Phase 25/26) enregistre plusieurs établissements et se connecte plusieurs fois en
# quelques secondes, dépassant les limites strictes par défaut (3 et 5/min) sans représenter un
# trafic réel à protéger dans cet environnement jetable.
# AUTH_THROTTLE_REGISTER_LIMIT=3
# AUTH_THROTTLE_LOGIN_LIMIT=5

# Bootstrap (seed initial, dev uniquement)
SUPER_ADMIN_EMAIL=superadmin@sih-saas.local
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Email (dev = jsonTransport, aucun envoi réseau ; smtp = réel via MAIL_HOST/PORT/USER/PASSWORD)
MAIL_TRANSPORT=dev
MAIL_FROM=no-reply@sih-saas.local
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# Paiement — SANDBOX, Wave et Orange Money sont câblées (Phase 17). Stripe/Carte restent à
# implémenter. Base publique de l'API pour les callbacks (notif_url Orange Money).
API_PUBLIC_URL=http://localhost:3000
PAYMENT_SUCCESS_URL=https://sih-saas.local/paiement/succes
PAYMENT_ERROR_URL=https://sih-saas.local/paiement/echec
PAYMENT_SANDBOX_WEBHOOK_SECRET=sandbox-dev-secret-change-me

# Wave Business Checkout — https://docs.wave.com/checkout (jamais testée en conditions réelles,
# aucune credential fournie ; laisser vide tant qu'un compte marchand Wave n'est pas obtenu)
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=

# Orange Money Web Payment — contrat reconstruit depuis des SDK tiers, aucune doc partenaire
# officielle accessible (à reconfirmer dès l'obtention d'un accès partenaire developer.orange.com)
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_ENV=dev

# Stripe (Carte) — https://docs.stripe.com/api/checkout/sessions/create (jamais testée en
# conditions réelles ; support du XOF non confirmé par Stripe, voir stripe-payment-gateway.ts)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
