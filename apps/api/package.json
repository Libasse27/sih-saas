{
  "name": "@sih-saas/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS — SIH SaaS Multi-Établissements",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "migration:generate": "pnpm build && node ./node_modules/typeorm/cli.js migration:generate -d dist/database/data-source.js",
    "migration:run": "pnpm build && node ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "migration:revert": "pnpm build && node ./node_modules/typeorm/cli.js migration:revert -d dist/database/data-source.js",
    "seed:rbac": "ts-node -r tsconfig-paths/register src/database/seeds/rbac.seed.ts",
    "seed:super-admin": "ts-node -r tsconfig-paths/register src/database/seeds/super-admin.seed.ts",
    "seed:plans": "ts-node -r tsconfig-paths/register src/database/seeds/plans.seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.4",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.4",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.22",
    "@sih-saas/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "mongoose": "^8.6.3",
    "nodemailer": "^6.9.15",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "typeorm": "^0.3.20",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/fhir": "^0.0.44",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.5",
    "@types/nodemailer": "^6.4.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1"
  }
}
