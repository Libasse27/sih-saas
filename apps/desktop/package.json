{
  "name": "@sih-saas/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Console desktop Electron + Vue (super-admin / établissement) — Phase 9",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.node.json",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "preview": "vite preview",
    "verify-gui": "node scripts/verify-gui.mjs",
    "e2e": "cypress run",
    "e2e:open": "cypress open"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@sih-saas/shared": "workspace:*",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.7.9",
    "chart.js": "^4.4.7",
    "dayjs": "^1.11.21",
    "pinia": "^2.3.0",
    "qrcode": "^1.5.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^20.16.5",
    "@types/qrcode": "^1.5.5",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "cypress": "^15.17.0",
    "electron": "^33.2.1",
    "eslint": "^9.39.0",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "playwright-core": "^1.61.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.11",
    "vue-tsc": "^2.2.0",
    "wait-on": "^8.0.1"
  }
}
