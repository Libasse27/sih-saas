# Variables consommées par docker-compose.prod.yml (pas par l'API elle-même, voir
# apps/api/.env.production.example pour celles-là). À copier en `.env.production`, jamais commité.
# Lancement : docker compose --env-file .env.production -f docker-compose.prod.yml up -d --build

# Rôle bootstrap Postgres (superuser, sert uniquement à l'initialisation du conteneur — l'API ne
# s'y connecte jamais, voir infrastructure/docker/postgres-init-prod/01-create-app-role.sh).
POSTGRES_BOOTSTRAP_USER=sih_saas
POSTGRES_BOOTSTRAP_PASSWORD=change-me-strong-password
POSTGRES_DB=sih_saas

# Mot de passe du rôle applicatif non-superuser (sih_saas_app) — celui que l'API utilise réellement
# (voir POSTGRES_PASSWORD dans apps/api/.env.production.example, qui doit avoir la MÊME valeur).
SIH_SAAS_APP_PASSWORD=change-me-strong-password

MONGO_ROOT_USER=sih_saas
MONGO_ROOT_PASSWORD=change-me-strong-password
MONGO_DB=sih_saas

REDIS_PASSWORD=change-me-strong-password

# Port hôte exposé pour l'API — lié à 127.0.0.1 uniquement (debug/tunnel SSH), jamais public.
# Le trafic public passe exclusivement par le service `nginx` (TLS, voir DOMAIN_NAME ci-dessous).
API_PORT=3000

# TLS (Phase 32, voir docs/tls-production.md) — domaine pointant déjà (DNS, enregistrement A) vers
# ce serveur AVANT de lancer infrastructure/docker/nginx/init-letsencrypt.sh. CERTBOT_EMAIL reçoit
# les alertes d'expiration de Let's Encrypt (renouvellement automatique normalement suffisant).
DOMAIN_NAME=sih-saas.example.com
CERTBOT_EMAIL=admin@example.com

# Sauvegardes quotidiennes Postgres+MongoDB (service `backup`, voir docs/plan-de-reprise.md) —
# réutilise les identifiants ci-dessus, aucune nouvelle credential à gérer. Nombre de jours de
# rétention avant purge automatique des sauvegardes locales (volume sih_saas_backups_data).
BACKUP_RETENTION_DAYS=30

# Phrase secrète de chiffrement AES256 (GPG symétrique) des archives de sauvegarde — appliquée
# systématiquement, hors-site activé ou non (chiffrement at-rest, voir docs/plan-de-reprise.md).
# OBLIGATOIRE : à générer indépendamment (ex. `openssl rand -base64 32`), à conserver hors de ce
# repo et hors du même stockage que les sauvegardes elles-mêmes — sans elle, aucune sauvegarde n'est
# récupérable, y compris par vous.
BACKUP_ENCRYPTION_PASSPHRASE=change-me-strong-passphrase

# Sauvegarde hors-site — désactivée par défaut (kill-switch, même philosophie que
# Settings.paiements.actifs) tant qu'aucun fournisseur de stockage objet n'est configuré avec de
# vraies credentials. Passer à "true" + renseigner les variables RCLONE_CONFIG_OFFSITE_* ci-dessous
# pour l'activer.
OFFSITE_BACKUP_ENABLED=false
OFFSITE_BACKUP_BUCKET=sih-saas-backups

# Remote rclone nommé "offsite" — convention officielle rclone (RCLONE_CONFIG_<NOM>_<OPTION>),
# agnostique du fournisseur compatible S3 (AWS S3, MinIO, Backblaze B2, Wasabi, OVH, Scaleway,
# DigitalOcean Spaces...). PROVIDER=AWS si AWS S3 lui-même, sinon PROVIDER=Other + ENDPOINT renseigné.
RCLONE_CONFIG_OFFSITE_TYPE=s3
RCLONE_CONFIG_OFFSITE_PROVIDER=Other
RCLONE_CONFIG_OFFSITE_ACCESS_KEY_ID=
RCLONE_CONFIG_OFFSITE_SECRET_ACCESS_KEY=
RCLONE_CONFIG_OFFSITE_ENDPOINT=
RCLONE_CONFIG_OFFSITE_REGION=auto
